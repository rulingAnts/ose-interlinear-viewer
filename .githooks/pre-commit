#!/bin/sh
# Updates CACHE_VERSION in sw.js to the current UTC timestamp on every commit.
# This ensures the service worker fetches a fresh cache after each deployment.
#
# This hook lives in .githooks/ (tracked by git) rather than .git/hooks/
# (untracked). Run `npm install` after cloning to activate it — the
# `prepare` script in package.json runs `git config core.hooksPath .githooks`.

TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Replace the CACHE_VERSION value in sw.js in-place.
# The sed -i '' form is required on macOS; Linux uses sed -i without the ''.
if sed --version 2>/dev/null | grep -q GNU; then
  sed -i "s|const CACHE_VERSION = '[^']*'|const CACHE_VERSION = '$TIMESTAMP'|" sw.js
else
  sed -i '' "s|const CACHE_VERSION = '[^']*'|const CACHE_VERSION = '$TIMESTAMP'|" sw.js
fi

git add sw.js
