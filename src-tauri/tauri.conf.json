{
  "productName": "OSE Interlinear Viewer",
  "version": "2.0.1",
  "identifier": "com.sethjohnston.ose-interlinear-viewer",
  "build": {
    "frontendDist": "../docs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OneStory Interlinearizer",
        "width": 680,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
